# ============================================================
# Backend Environment Variables — Deployment Configuration
# ============================================================
# Copy these into your backend host (Railway, Render, Fly.io).
# Set them in the platform's environment variable settings.
# DO NOT commit this file with real values.
# ============================================================

# [REQUIRED] Your OpenAI API key.
# Get one at: https://platform.openai.com/api-keys
# ROTATE IMMEDIATELY if this was ever committed to git.
OPENAI_API_KEY=sk-proj-your-real-key-here

# [REQUIRED] Secret key used to authenticate frontend → backend requests.
# Must match VITE_API_KEY on the frontend (Vercel).
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your_secure_32_char_hex_key_here

# [REQUIRED for production] Comma-separated list of allowed frontend origins.
# Set to your Vercel deployment URL. Do NOT use * in production.
# Example: https://university-policy-ai.vercel.app
CORS_ORIGINS=https://your-app.vercel.app

# [OPTIONAL] Path to the directory where uploaded PDFs are stored.
# On Railway/Render with a persistent disk, mount the disk and point here.
# Default: ./data
DATA_DIR=./data

# [OPTIONAL] Path to ChromaDB persistent storage.
# On Railway/Render with a persistent disk, mount the disk and point here.
# Default: ./chroma_db
CHROMA_DB_PATH=./chroma_db

# [OPTIONAL] Path to the query history JSON file.
# Leave unset to use in-memory history only (resets on restart).
# HISTORY_FILE=./history.json
