# ============================================================
# Frontend Environment Variables — Vercel Configuration Guide
# ============================================================
# Copy these into Vercel: Settings → Environment Variables
# DO NOT commit real values. This file is safe to commit.
# ============================================================

# The URL of your deployed FastAPI backend.
# Example: https://your-backend-app.railway.app
# NOTE: Vercel hosts the frontend only. The Python backend must
# be deployed separately (Railway, Render, Fly.io, etc.)
VITE_API_BASE_URL=https://your-backend-url.railway.app

# The API key used to authenticate requests to the backend.
# Must match the API_KEY env var set on your backend deployment.
# Generate a secure key: python3 -c "import secrets; print(secrets.token_hex(32))"
VITE_API_KEY=your_secure_api_key_here
